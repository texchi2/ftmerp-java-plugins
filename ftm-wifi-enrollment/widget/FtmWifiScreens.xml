<?xml version="1.0" encoding="UTF-8"?>
<screens xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns="http://ofbiz.apache.org/Widget-Screen"
    xsi:schemaLocation="http://ofbiz.apache.org/Widget-Screen http://ofbiz.apache.org/dtds/widget-screen.xsd">

    <!-- Main decorator -->
    <screen name="main-decorator">
        <section>
            <widgets>
                <decorator-screen name="main-decorator"
                    location="${parameters.mainDecoratorLocation}">
                    <decorator-section name="pre-body">
                        <include-menu name="FtmWifiAppBar"
                            location="component://ftm-wifi-enrollment/widget/FtmWifiMenus.xml"/>
                    </decorator-section>
                    <decorator-section name="body">
                        <decorator-section-include name="body"/>
                    </decorator-section>
                </decorator-screen>
            </widgets>
        </section>
    </screen>

    <!-- ==================== FIND / LIST SCREEN ==================== -->
    <screen name="FindAuthorizedUsers">
        <section>
            <actions>
                <service service-name="getFtmAuthorizedUsers" result-map="serviceResult">
                    <field-map field-name="department"  from-field="parameters.department"/>
                    <field-map field-name="vlanTier"    from-field="parameters.vlanTier"/>
                    <field-map field-name="activeOnly"  value="false"/>
                </service>
                <set field="userList"  from-field="serviceResult.userList"/>
                <set field="userCount" from-field="serviceResult.userCount"/>
            </actions>
            <widgets>
                <decorator-screen name="main-decorator" location="${parameters.mainDecoratorLocation}">
                    <decorator-section name="body">
                        <screenlet title="WiFi Authorized Users (${userCount} total)">
                            <include-form name="FindUsersFilter"
                                location="component://ftm-wifi-enrollment/widget/FtmWifiForms.xml"/>
                        </screenlet>
                        <screenlet title="User List">
                            <link text="Export CSV"
                                target="ExportAuthorizedUsersCsv"
                                style="buttontext" url-mode="intra-app"/>
                            <include-form name="AuthorizedUserList"
                                location="component://ftm-wifi-enrollment/widget/FtmWifiForms.xml"/>
                        </screenlet>
                    </decorator-section>
                </decorator-screen>
            </widgets>
        </section>
    </screen>

    <!-- ==================== EDIT SCREEN ==================== -->
    <screen name="EditAuthorizedUser">
        <section>
            <actions>
                <script location="component://ftm-wifi-enrollment/groovyScripts/ftm/wifi/EditUserActions.groovy"/>
            </actions>
            <widgets>
                <decorator-screen name="main-decorator" location="${parameters.mainDecoratorLocation}">
                    <decorator-section name="body">
                        <screenlet title="${titleProperty}">
                            <include-form name="EditUserForm"
                                location="component://ftm-wifi-enrollment/widget/FtmWifiForms.xml"/>
                            <platform-specific>
                                <html><html-template
                                    location="component://ftm-wifi-enrollment/template/DeleteUserButton.ftl"/>
                                </html>
                            </platform-specific>
                        </screenlet>
                        <screenlet title="Enrolled Devices">
                            <include-form name="EnrolledDevicesList"
                                location="component://ftm-wifi-enrollment/widget/FtmWifiForms.xml"/>
                        </screenlet>
                    </decorator-section>
                </decorator-screen>
            </widgets>
        </section>
    </screen>

    <!-- ==================== IMPORT SCREENS ==================== -->
    <screen name="ImportWifiUsers">
        <section>
            <widgets>
                <decorator-screen name="main-decorator" location="${parameters.mainDecoratorLocation}">
                    <decorator-section name="body">
                        <screenlet title="Import Staff from Excel">
                            <include-form name="UploadExcelForm"
                                location="component://ftm-wifi-enrollment/widget/FtmWifiForms.xml"/>
                            <label style="heading">
                                Excel columns: Employee ID | Full Name | Username | Department |
                                Position | Device Quota | FTM-Staff VLAN10 (Y/N) | Notes
                            </label>
                        </screenlet>
                    </decorator-section>
                </decorator-screen>
            </widgets>
        </section>
    </screen>

    <screen name="ImportPreview">
        <section>
            <actions>
                <script location="component://ftm-wifi-enrollment/groovyScripts/ftm/wifi/ImportPreviewActions.groovy"/>
            </actions>
            <widgets>
                <decorator-screen name="main-decorator" location="${parameters.mainDecoratorLocation}">
                    <decorator-section name="body">
                        <screenlet title="Import Preview — Review Before Committing">
                            <include-form name="ImportPreviewTable"
                                location="component://ftm-wifi-enrollment/widget/FtmWifiForms.xml"/>
                            <include-form name="ImportCommitForm"
                                location="component://ftm-wifi-enrollment/widget/FtmWifiForms.xml"/>
                        </screenlet>
                    </decorator-section>
                </decorator-screen>
            </widgets>
        </section>
    </screen>

    <screen name="ImportSummary">
        <section>
            <actions>
                <script location="component://ftm-wifi-enrollment/groovyScripts/ftm/wifi/ImportSummaryActions.groovy"/>
            </actions>
            <widgets>
                <decorator-screen name="main-decorator" location="${parameters.mainDecoratorLocation}">
                    <decorator-section name="body">
                        <screenlet title="Import Complete">
                            <label>Added: ${addedCount} | Updated: ${updatedCount} | Skipped: ${skippedCount}</label>
                            <include-form name="ImportSummaryForm"
                                location="component://ftm-wifi-enrollment/widget/FtmWifiForms.xml"/>
                        </screenlet>
                    </decorator-section>
                </decorator-screen>
            </widgets>
        </section>
    </screen>

</screens>
