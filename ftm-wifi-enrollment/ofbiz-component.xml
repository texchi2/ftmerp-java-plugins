<?xml version="1.0" encoding="UTF-8"?>
<ofbiz-component name="ftm-wifi-enrollment"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="http://ofbiz.apache.org/dtds/ofbiz-component.xsd">

    <resource-loader name="main" type="component"/>

    <!-- Entity model for authorized_users and audit log -->
    <entity-resource type="model" reader-name="main" loader="main"
        location="entitydef/entitymodel_ftm_wifi.xml"/>

    <!-- Entity group mapping for external PostgreSQL datasource -->
    <entity-resource type="group" reader-name="main" loader="main"
        location="entitydef/entitygroup_ftm_wifi.xml"/>

    <!-- Service definitions -->
    <service-resource type="model" loader="main"
        location="servicedef/services_ftm_wifi.xml"/>

    <!-- Web application -->
    <webapp name="ftm-wifi"
        title="FTM WiFi Enrollment"
        server="default-server"
        location="webapp/ftm-wifi"
        base-permission="OFBTOOLS"
        mount-point="/ftm-wifi"/>

</ofbiz-component>
